{
  "name": "aboslutt",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "test:billing": "node --test scripts/test-billing-flow.mjs",
    "test:launch": "node --test scripts/test-launch-readiness.mjs",
    "test:microsoft-import": "node --test scripts/test-microsoft-outlook-import.mjs",
    "test:analytics": "node --test scripts/test-analytics-privacy.mjs",
    "test:auth-providers": "node --test scripts/test-auth-provider-config.mjs",
    "test:auth-account-linking": "node --test scripts/test-auth-account-linking.mjs",
    "test:billing-outlook-state": "node --test scripts/test-billing-outlook-state.mjs",
    "test:subscription-lifecycle": "node --test scripts/test-subscription-lifecycle.mjs",
    "test:provider-catalog": "node --test scripts/test-subscription-provider-catalog.mjs",
    "test:playwright-server": "node --test scripts/test-playwright-server-process.mjs",
    "test:provider-logo-importer": "node --test scripts/test-provider-logo-importer.mjs",
    "test:cancellation-sending": "node --test scripts/test-cancellation-sending.mjs",
    "test:repair-migration": "node --test scripts/test-repair-unmatched-provider-signal.mjs",
    "test:unit": "npm run test:launch && npm run test:billing && npm run test:microsoft-import && npm run test:analytics && npm run test:auth-providers && npm run test:auth-account-linking && npm run test:billing-outlook-state && npm run test:subscription-lifecycle && npm run test:provider-catalog && npm run test:provider-logo-importer && npm run test:cancellation-sending && npm run test:repair-migration && npm run test:playwright-server",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "check:text": "node scripts/check-text-encoding.mjs",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "node scripts/check-database-url.mjs && prisma migrate deploy",
    "prisma:seed": "node scripts/check-database-url.mjs && prisma db seed",
    "providers:match": "node scripts/match-subscription-providers.mjs",
    "prisma:reset": "prisma migrate reset --force"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.19.3",
    "@sentry/nextjs": "^10.60.0",
    "@vercel/blob": "^2.4.1",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "next": "16.2.9",
    "next-auth": "^4.24.14",
    "nodemailer": "^7.0.13",
    "posthog-js": "^1.392.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
