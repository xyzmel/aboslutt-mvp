# Core app
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
DATABASE_URL=

# Playwright E2E (must be a separate disposable Postgres database)
E2E_DATABASE_URL=
E2E_BASE_URL=http://127.0.0.1:3100
E2E_PORT=3100
# Only for an explicitly approved remote test database without e2e/test/playwright in its name
E2E_ALLOW_REMOTE_DATABASE=false

# PostHog analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
POSTHOG_PROJECT_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com
NEXT_PUBLIC_ENABLE_ANALYTICS_LOCAL=false
NEXT_PUBLIC_ANALYTICS_CONSENT_REQUIRED=false

# Sentry error monitoring
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_RELEASE=
NEXT_PUBLIC_SENTRY_RELEASE=

# Email magic-link and transactional email
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=

# Google auth and Gmail import
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_MAIL_CONNECT_ENABLED=false

# Microsoft login and Outlook import
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/import/microsoft/callback
MICROSOFT_TOKEN_ENCRYPTION_KEY=

# Vipps Recurring
VIPPS_RECURRING_CLIENT_ID=
VIPPS_RECURRING_CLIENT_SECRET=
VIPPS_RECURRING_SUBSCRIPTION_KEY=
VIPPS_RECURRING_MERCHANT_SERIAL_NUMBER=
VIPPS_RECURRING_BASE_URL=
VIPPS_WEBHOOK_SECRET=

# Optional admin and jobs
CRON_SECRET=
